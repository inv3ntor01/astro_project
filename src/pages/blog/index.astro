---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => a.data.id - b.data.id);
---

<Layout title="Blog | CS Baron-Vergara">
	<main class="pt-24 md:pt-32 pb-16 md:pb-24 px-6 md:px-8 max-w-7xl mx-auto">
		<header class="mb-12 md:mb-20 text-center">
			<span class="font-label text-primary uppercase tracking-[0.3em] text-[10px] md:text-xs mb-4 md:mb-6 block">STREET WONDERLAND</span>
			<h1 class="font-headline text-4xl md:text-7xl font-bold tracking-tighter text-white leading-tight">
				SAMPUNG TULA<span class="text-primary italic">NANG PAGLIMOT</span>
			</h1>
		</header>
        
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
			{sortedPosts.map(post => (
				<a href={`/blog/${post.id}`} class="group bg-surface-container-low p-6 md:p-8 rounded-lg hover:bg-surface-container hover:border-primary border border-transparent transition-all duration-300">
                    <span class="text-primary font-bold text-[10px] md:text-xs uppercase tracking-widest block mb-3 md:mb-4">
                        {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                    </span>
                    <h2 class="text-xl md:text-2xl font-headline font-bold text-white group-hover:text-primary mb-3 md:mb-4 transition-colors">
                        {post.data.title}
                    </h2>
                    <p class="text-on-surface-variant text-sm leading-relaxed line-clamp-3">{post.data.description}</p>
				</a>
			))}
		</div>
	</main>
    
</Layout>
