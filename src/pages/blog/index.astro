---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout title="Blog | Engr. Christine Sheen Ligan Baron-Vergara">
	<main class="pt-32 pb-24 px-8 max-w-7xl mx-auto">
		<header class="mb-20 text-center">
			<span class="font-label text-primary uppercase tracking-[0.3em] text-xs mb-6 block">Editorial Archives</span>
			<h1 class="font-headline text-6xl md:text-7xl font-bold tracking-tighter text-white">
				SAMPUNG TULA <span class="text-primary italic">NANG PAGLIMOT</span>
			</h1>
		</header>
        
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
			{posts.map(post => (
				<a href={`/blog/${post.id}`} class="group bg-surface-container-low p-8 rounded-lg hover:bg-surface-container hover:border-primary border border-transparent transition-all duration-300">
                    <span class="text-primary font-bold text-xs uppercase tracking-widest block mb-4">
                        {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                    </span>
                    <h2 class="text-2xl font-headline font-bold text-white group-hover:text-primary mb-4 transition-colors">
                        {post.data.title}
                    </h2>
                    <p class="text-on-surface-variant text-sm leading-relaxed">{post.data.description}</p>
				</a>
			))}
		</div>
	</main>
    
</Layout>
