    { year: '2022', title: 'Laboratory Safety Series III', org: 'Topic: Laboratory Equipment and Facilities', link: 'https://drive.google.com/file/d/1f_2FagvNej1ao_tkZYsnhGrYE1U6l4ve/view?usp=drive_link' },
    { year: '2022', title: 'Development Management 1: The Leadership That We Want!', org: 'Universidad de Sta. Isabel, Elias Angeles St., Naga City', link: 'https://drive.google.com/file/d/1mHQOD8zDtsVoEowTDbd7rHjMn1PIzECx/view?usp=drive_link' },
    { year: '2021', title: 'Introduction to Kubernetes', org: 'Trend Micro', link: 'https://drive.google.com/file/d/1NkBjWh5UkgPX1F6b3LgXwyEEGE1Lzx2U/view?usp=drive_link' },
    { year: '2021', title: '1st International Conference on Emerging Technologies and Innovations (ICETI - 1)', org: 'University of Mindanao', link: 'https://drive.google.com/file/d/12VTD1GQDeIs4iiU2y1xAWlL-cgr7yAaJ/view?usp=drive_link' },
