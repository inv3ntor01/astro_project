---
import Layout from '../layouts/Layout.astro';

const technicalSkills = [
    'Networking Protocols', 'Device Programming', 'Video & Audio Editing',
    'Multimedia Networks', 'ChatGPT', 'Google Suites', 'Canva',
    'Office 365', 'Social Media Mgmt', 'WordPress', 'E-commerce',
    'Zoho', 'Asana', 'Trello', 'Airtable', 'Slack'
];

const affiliations = [
    { title: 'Regional Vice President for External Affairs', org: 'ICPEP Region 11 (2025 – Present)' },
    { title: 'Member for Professional Membership', org: 'ICPEP National Board (2023 – 2024)' },
    { title: 'Chapter President', org: 'ICPEP Region 11 (2023 – 2024)' },
    { title: 'Professional Development Officer', org: 'ICPEP Region 11 (2022)' }
];

const achievements = [
    { year: '2023', title: 'Most Valuable Employee', org: 'X10 Technologies', link: 'https://drive.google.com/file/d/1wsc4fZiU5ytVxS2zkuxHGZrvQB-NcPuE/view?usp=sharing' },
    { year: 'Award', title: 'Engineering Oratorical Champion', org: 'University of Mindanao', link: 'https://drive.google.com/file/d/1wsc4fZiU5ytVxS2zkuxHGZrvQB-NcPuE/view?usp=sharing' },
    { year: 'International', title: '1st International Convention Awardee', org: 'ICPEP Muscat, Oman', link: 'https://drive.google.com/file/d/1wsc4fZiU5ytVxS2zkuxHGZrvQB-NcPuE/view?usp=sharing' },
    { year: 'Research', title: 'Top 10 Research Presenter', org: 'CODEE Research Congress XI', link: 'https://drive.google.com/file/d/1wsc4fZiU5ytVxS2zkuxHGZrvQB-NcPuE/view?usp=sharing ' },
    { year: 'Runner-up', title: 'Essay Writing Champion', org: 'UM Davao Intramurals', link: 'https://drive.google.com/file/d/1wsc4fZiU5ytVxS2zkuxHGZrvQB-NcPuE/view?usp=sharing '},
    { year: 'Speaker', title: 'Python Enhancement Speaker', org: 'University of Mindanao', link: 'https://drive.google.com/file/d/1wsc4fZiU5ytVxS2zkuxHGZrvQB-NcPuE/view?usp=sharing '}
];
---

<Layout title="Engr. Christine Sheen Ligan Baron-Vergara | Portfolio">
    {/* TopNavBar */}
    <nav class="fixed top-0 w-full z-50 bg-background/60 backdrop-blur-xl">
        <div class="flex justify-between items-center px-8 py-6 max-w-7xl mx-auto w-full">
            <span class="text-2xl font-bold tracking-tighter text-primary">ENGR. CS</span>
            <div class="hidden md:flex gap-8 items-center">
                <a
                    class="font-headline uppercase tracking-widest text-sm text-primary border-b-2 border-primary pb-1 hover:text-primary transition-colors duration-300 scale-95 active:duration-100"
                    href="/"
                >
                    Home
                </a>
                <a
                    class="font-headline uppercase tracking-widest text-sm text-white/70 hover:text-primary transition-colors duration-300 scale-95 active:duration-100"
                    href="/blog"
                >
                    Writeups
                </a>
                <a
                    class="font-headline uppercase tracking-widest text-sm text-white/70 hover:text-primary transition-colors duration-300 scale-95 active:duration-100"
                    href="/contact"
                >
                    Contact
                </a>
            </div>
            <div class="flex items-center gap-4">
                <button class="material-symbols-outlined text-primary hover:scale-110 transition-transform">
                    dark_mode
                </button>
            </div>
        </div>
    </nav>

    <main class="pt-24">
        {/* Hero Section */}
        <section class="max-w-7xl mx-auto px-8 py-20 lg:py-32 grid lg:grid-cols-12 gap-12 items-center">
            <div class="lg:col-span-7">
                <p class="text-primary font-headline tracking-[0.3em] uppercase text-sm mb-6">PROFESSIONAL PORTFOLIO</p>
                <h1 class="text-5xl lg:text-7xl font-bold font-headline leading-[1.1] mb-8 tracking-tighter text-on-surface">
                    Engr. Christine Sheen <span class="text-primary">L. Baron-Vergara</span>
                </h1>
                <p class="text-xl text-on-surface-variant font-light max-w-2xl mb-10 leading-relaxed">
                    Senior Technical Content Writer & Computer Engineer. Bridging the gap between complex engineering concepts and accessible digital narratives.
                </p>
                <div class="flex flex-wrap gap-4">
                    <a
                        href="/contact"
                        class="bg-gradient-to-r from-primary to-primary-container text-on-primary px-10 py-4 rounded-lg font-bold text-sm tracking-widest uppercase hover:opacity-90 transition-all"
                    >
                        Contact Me
                    </a>
                    <button
                        onclick="window.open('https://drive.google.com/file/d/1Vwc1vTizW_bmAb3fBd2BCIDlyw8ZedZF/view?usp=sharing', '_blank')"
                        class="border border-outline-variant/20 text-on-surface px-10 py-4 rounded-lg font-bold text-sm tracking-widest uppercase hover:bg-surface-container-low transition-all">
                        View Resume
                    </button>
                </div>
            </div>
            <div class="lg:col-span-5 relative">
                <div class="aspect-[4/5] bg-surface-container-low rounded-lg overflow-hidden white hover:grayscale-0 transition-all duration-700">
                    <img
                        class="w-full h-full object-cover"
                        alt="Professional portrait of Engr. Christine Sheen"
                        src="https://lh3.googleusercontent.com/aida-public/AB6AXuD1u-wJXqLIrJ5Cjvl05O0EViKVuDb_qZG6Ab5V_TvFlmUl4dRMHQs4QX1-A9qAQSVVJv2njmYH6Pb424z6KqAXqmRgd1k-u-YzaBk14lQZUBbFBZU9My-LBi6z5G_cdycIvOtLLuoQi105yaz0QUV7chMZIdanA_Pkp9qQesJBmLOdw2KQh6d3b6wC3oKYd48_jGZyieW7XTs_A7R2-w64XNYE0v9ejBJPH8xi0OH35T96jVUQhOJ0ETBhuG5XeRWQRbf79iVxXOI"
                    />
                </div>
                <div class="absolute -bottom-6 -left-6 bg-primary text-on-primary p-6 rounded-lg hidden md:block">
                    <p class="text-3xl font-bold font-headline">10+</p>
                    <p class="text-xs uppercase tracking-tighter opacity-80">Years of Experience</p>
                </div>
            </div>
        </section>

        {/* About & Bento Grid */}
        <section class="bg-surface-container-low py-24">
            <div class="max-w-7xl mx-auto px-8">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                    {/* About Me */}
                    <div class="md:col-span-2 bg-surface p-10 rounded-lg">
                        <h2 class="text-3xl font-bold font-headline mb-8 text-primary">About Me</h2>
                        <p class="text-on-surface-variant leading-relaxed text-lg">
                            With a dual background in Computer Engineering and Technical Writing, I specialize in distilling intricate technological frameworks into compelling, high-authority content. My approach combines technical precision with editorial flair, ensuring that every project is both accurate and engaging.
                        </p>
                        <div class="mt-12 grid grid-cols-2 gap-8 border-t border-outline-variant/10 pt-10">
                            <div>
                                <h4 class="text-primary font-headline text-sm uppercase tracking-widest mb-2">Location</h4>
                                <p class="text-on-surface">Davao City, Philippines</p>
                            </div>
                            <div>
                                <h4 class="text-primary font-headline text-sm uppercase tracking-widest mb-2">Specialization</h4>
                                <p class="text-on-surface">ISO/IEC 27001, Document Manager, ISO Auditor, Startup Mentor, Business Analyst</p>
                            </div>
                        </div>
                    </div>
                    {/* Strengths */}
                    <div class="bg-surface-container-highest p-10 rounded-lg flex flex-col justify-between">
                        <div>
                            <h2 class="text-3xl font-bold font-headline mb-8 text-white">Strengths</h2>
                            <ul class="space-y-6">
                                <li class="flex items-center gap-4">
                                    <span class="material-symbols-outlined text-primary">chat</span>
                                    <span class="text-on-surface font-medium">Precise Verbal Communication</span>
                                </li>
                                <li class="flex items-center gap-4">
                                    <span class="material-symbols-outlined text-primary">edit_note</span>
                                    <span class="text-on-surface font-medium">Proficient Technical Writing</span>
                                </li>
                                <li class="flex items-center gap-4">
                                    <span class="material-symbols-outlined text-primary">groups</span>
                                    <span class="text-on-surface font-medium">Excellent Team Coordination</span>
                                </li>
                                <li class="flex items-center gap-4">
                                    <span class="material-symbols-outlined text-primary">bolt</span>
                                    <span class="text-on-surface font-medium">High Efficiency & Productivity</span>
                                </li>
                                <li class="flex items-center gap-4">
                                    <span class="material-symbols-outlined text-primary">build</span>
                                    <span class="text-on-surface font-medium">Technical Troubleshooting</span>
                                </li>
                                <li class="flex items-center gap-4">
                                    <span class="material-symbols-outlined text-primary">leaderboard</span>
                                    <span class="text-on-surface font-medium">Adaptable Leadership</span>
                                </li>
                            </ul>
                        </div>
                        <div class="mt-8">
                            <span class="text-4xl material-symbols-outlined text-white/20">format_quote</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        {/* Work Experience Timeline */}
        <section class="max-w-7xl mx-auto px-8 py-24">
            <h2 class="text-4xl font-bold font-headline mb-16 text-center">Work <span class="text-primary">Experience</span></h2>
            <div class="space-y-12 relative before:absolute before:left-0 md:before:left-1/2 before:w-[1px] before:h-full before:bg-outline-variant/30">
                {/* Item 1 */}
                <div class="relative flex flex-col md:flex-row items-center gap-8 group">
                    <div class="md:w-1/2 md:text-right pr-8 order-2 md:order-1">
                        <span class="text-primary font-bold font-headline text-sm tracking-widest mb-2 block">OCTOBER 2025 — PRESENT</span>
                        <h3 class="text-2xl font-bold text-white mb-2">TikTok Live Gaming Streamer</h3>
                        <p class="text-on-surface-variant italic mb-4">Self-Managed</p>
                        <p class="text-on-surface-variant max-w-md ml-auto">Creates and manages social media platforms and content.</p>
                    </div>
                    <div class="absolute left-[-10px] md:left-1/2 md:translate-x-[-50%] w-5 h-5 bg-primary rounded-full z-10 border-4 border-surface shadow-[0_0_15px_rgba(255,20,147,0.4)]"></div>
                    <div class="md:w-1/2 order-3"></div>
                </div>
                {/* Item 2 */}
                <div class="relative flex flex-col md:flex-row items-center gap-8 group">
                    <div class="md:w-1/2 order-2 md:order-1"></div>
                    <div class="absolute left-[-10px] md:left-1/2 md:translate-x-[-50%] w-5 h-5 bg-primary-container rounded-full z-10 border-4 border-surface shadow-[0_0_15px_rgba(255,71,156,0.4)]"></div>
                    <div class="md:w-1/2 pl-8 order-3">
                        <span class="text-primary font-bold font-headline text-sm tracking-widest mb-2 block">SEPTEMBER 2023 — JANUARY 2026</span>
                        <h3 class="text-2xl font-bold text-white mb-2">Senior Technical Content Writer</h3>
                        <p class="text-on-surface-variant italic mb-4">X10 Technologies, Inc.</p>
                        <p class="text-on-surface-variant max-w-md">Global Document Custodian, Records Department Head, Policies and Manuals Writer. Handling RFPs (Canada, US, & Philippines), Technical Reports, Document Controls, Formatting, and Branding.</p>
                    </div>
                </div>
                {/* Item 3 */}
                <div class="relative flex flex-col md:flex-row items-center gap-8 group">
                    <div class="md:w-1/2 md:text-right pr-8 order-2 md:order-1">
                        <span class="text-primary font-bold font-headline text-sm tracking-widest mb-2 block">JULY 2020 — SEPTEMBER 2023</span>
                        <h3 class="text-2xl font-bold text-white mb-2">Technical Content Writer</h3>
                        <p class="text-on-surface-variant italic mb-4">X10 Technologies, Inc.</p>
                        <p class="text-on-surface-variant max-w-md ml-auto">Creating and managing technical documentation and content.</p>
                    </div>
                    <div class="absolute left-[-10px] md:left-1/2 md:translate-x-[-50%] w-5 h-5 bg-primary rounded-full z-10 border-4 border-surface shadow-[0_0_15px_rgba(255,20,147,0.4)]"></div>
                    <div class="md:w-1/2 order-3"></div>
                </div>
                {/* Item 4 */}
                <div class="relative flex flex-col md:flex-row items-center gap-8 group">
                    <div class="md:w-1/2 order-2 md:order-1"></div>
                    <div class="absolute left-[-10px] md:left-1/2 md:translate-x-[-50%] w-5 h-5 bg-primary-container rounded-full z-10 border-4 border-surface shadow-[0_0_15px_rgba(255,71,156,0.4)]"></div>
                    <div class="md:w-1/2 pl-8 order-3">
                        <span class="text-primary font-bold font-headline text-sm tracking-widest mb-2 block">JANUARY 2022 — JANUARY 2023</span>
                        <h3 class="text-2xl font-bold text-white mb-2">Program Head for Computer Engineering</h3>
                        <p class="text-on-surface-variant italic mb-4">University of Mindanao Digos College</p>
                        <p class="text-on-surface-variant max-w-md">Leadership role in the Computer Engineering program.</p>
                    </div>
                </div>
                {/* Item 5 */}
                <div class="relative flex flex-col md:flex-row items-center gap-8 group">
                    <div class="md:w-1/2 md:text-right pr-8 order-2 md:order-1">
                        <span class="text-primary font-bold font-headline text-sm tracking-widest mb-2 block">JUNE 2019 — JANUARY 2022</span>
                        <h3 class="text-2xl font-bold text-white mb-2">Engineering Faculty & Lab Custodian</h3>
                        <p class="text-on-surface-variant italic mb-4">University of Mindanao Digos College</p>
                        <p class="text-on-surface-variant max-w-md ml-auto">Academic instruction and laboratory management.</p>
                    </div>
                    <div class="absolute left-[-10px] md:left-1/2 md:translate-x-[-50%] w-5 h-5 bg-primary rounded-full z-10 border-4 border-surface shadow-[0_0_15px_rgba(255,20,147,0.4)]"></div>
                    <div class="md:w-1/2 order-3"></div>
                </div>
                {/* Item 6 */}
                <div class="relative flex flex-col md:flex-row items-center gap-8 group">
                    <div class="md:w-1/2 order-2 md:order-1"></div>
                    <div class="absolute left-[-10px] md:left-1/2 md:translate-x-[-50%] w-5 h-5 bg-primary-container rounded-full z-10 border-4 border-surface shadow-[0_0_15px_rgba(255,71,156,0.4)]"></div>
                    <div class="md:w-1/2 pl-8 order-3">
                        <span class="text-primary font-bold font-headline text-sm tracking-widest mb-2 block">MAY 2020 — OCTOBER 2020</span>
                        <h3 class="text-2xl font-bold text-white mb-2">Multi-skilled Virtual Assistant</h3>
                        <p class="text-on-surface-variant italic mb-4">TaskBullet Philippines</p>
                        <p class="text-on-surface-variant max-w-md">Providing diverse virtual assistance services.</p>
                    </div>
                </div>
            </div>
        </section>

        {/* Technical Skills & Affiliations */}
        <section class="bg-surface-container py-24">
            <div class="max-w-7xl mx-auto px-8 grid lg:grid-cols-2 gap-20">
                <div>
                    <h2 class="text-3xl font-bold font-headline mb-10 text-primary">Technical Skills</h2>
                    <div class="flex flex-wrap gap-3">
                        {technicalSkills.map((skill) => (
                            <span class="px-6 py-2 bg-surface-container-highest text-secondary font-medium rounded-full text-sm border border-outline-variant/10">
                                {skill}
                            </span>
                        ))}
                    </div>
                    <h2 class="text-3xl font-bold font-headline mb-10 mt-20 text-white">Affiliations</h2>
                    <div class="space-y-6">
                        {affiliations.map((aff) => (
                            <div class="flex items-start gap-4 p-4 bg-surface-container-low rounded-lg border-l-4 border-primary">
                                <span class="material-symbols-outlined text-primary pt-1">verified</span>
                                <div>
                                    <p class="font-bold text-on-surface">{aff.title}</p>
                                    <p class="text-xs text-on-surface-variant uppercase tracking-widest">{aff.org}</p>
                                </div>
                            </div>
                        ))}
                    </div>
                </div>
                <div class="grid grid-rows-2 gap-8">
                    {/* Education */}
                    <div class="bg-surface p-8 rounded-lg border border-outline-variant/10">
                        <h2 class="text-2xl font-bold font-headline mb-6 text-primary flex items-center gap-3">
                            <span class="material-symbols-outlined">school</span> Education
                        </h2>
                        <div class="space-y-6">
                            <div>
                                <p class="font-bold text-on-surface">BS in Computer Engineering</p>
                                <p class="text-sm text-on-surface-variant">University of Mindanao</p>
                                <p class="text-xs text-primary mt-1">Graduated April 2019</p>
                            </div>
                            <div class="border-t border-outline-variant/10 pt-4">
                                <p class="font-bold text-on-surface">Master of Business Administration</p>
                                <p class="text-sm text-on-surface-variant">Ongoing Research</p>
                            </div>
                        </div>
                    </div>
                    {/* Certifications */}
                    <div class="bg-surface p-8 rounded-lg border border-outline-variant/10">
                        <h2 class="text-2xl font-bold font-headline mb-6 text-primary flex items-center gap-3">
                            <span class="material-symbols-outlined">card_membership</span> Certifications
                        </h2>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            {[
                                'Google Analytics Certified','Certified Computer Engineer', 'Program Advisory Council',
                                'Introduction to Kubernetes', 'Development Mangement', 'Laboratory Safety Training Series III',
                                'Case Assessment and Initial Industry Matching', 'DICT-DLS002 Navigating Google Workspace',
                                'DICT-ICT001 Digital Innovation in Government', 'DICT-DLS005 Designing Presentation Slides',
                                'Professional Organization Representative', 'Aruba Data Center Essentials'
                            ].map((cert) => (
                                <div class="p-3 bg-surface-container-low rounded">
                                    <p class="text-sm font-bold">{cert}</p>
                                </div>
                            ))}
                        </div>
                    </div>
                </div>
            </div>
        </section>

        {/* Seminars & Achievements */}
        <section class="max-w-7xl mx-auto px-8 py-24">
            <h2 class="text-4xl font-bold font-headline mb-16">Seminars & <span class="text-primary">Achievements</span></h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {achievements.map((ach) => (
                    <a
                            href={ach.link}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="group bg-surface-container-low p-8 rounded-lg hover:bg-primary transition-all duration-300"
                    >
                        <p class="text-primary group-hover:text-on-primary font-bold mb-4">{ach.year}</p>
                        <h4 class="text-lg font-headline font-bold text-white group-hover:text-on-primary mb-2">{ach.title}</h4>
                        <p class="text-sm text-on-surface-variant group-hover:text-on-primary/80">{ach.org}</p>
                    </a>
                ))}
            </div>
        </section>
    </main>

    {/* Footer Execution */}
    <footer class="bg-surface-container-lowest w-full py-12 px-8 mt-20">
        <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-8">
            <div class="text-center md:text-left">
                <span class="font-headline text-lg text-white block mb-2 uppercase">engr. cs</span>
                <p class="font-body text-xs tracking-tight text-white/40">© 2026 Virtual Buddy Solutions</p>
            </div>
            <div class="flex gap-8">
                <a class="text-primary font-body text-xs tracking-tight uppercase hover:text-white transition-opacity opacity-80 hover:opacity-100" href="mailto:engineerbaron28@gmail.com">Gmail</a>
                <a class="text-primary font-body text-xs tracking-tight uppercase hover:text-white transition-opacity opacity-80 hover:opacity-100" href="#">Facebook</a>
                <a class="text-primary font-body text-xs tracking-tight uppercase hover:text-white transition-opacity opacity-80 hover:opacity-100" href="https://www.linkedin.com/in/engrchristinevergara/">LinkedIn</a>
            </div>
            <div class="text-right">
                <p class="font-body text-xs tracking-tight text-white/20">DESIGNED BY INV3NTOR</p>
            </div>
        </div>
    </footer>
</Layout>
