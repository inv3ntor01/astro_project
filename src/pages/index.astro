---
import Layout from '../layouts/Layout.astro';
import WorkExperienceTimeline from '../components/WorkExperienceTimeline.astro';
import CertModal from '../components/CertModal.astro';


const technicalSkills = [
    'Networking Protocols', 'Device Programming', 'Video & Audio Editing',
    'Multimedia Networks', 'ChatGPT', 'Google Suites', 'Canva',
    'Office 365', 'Social Media Mgmt', 'WordPress', 'E-commerce',
    'Zoho', 'Asana', 'Trello', 'Airtable', 'Slack'
];

const affiliations = [
    { title: 'Regional Vice President for External Affairs', org: 'ICPEP Region 11 (2025 – Present)' },
    { title: 'Member for Professional Membership', org: 'ICPEP National Board (2023 – 2024)' },
    { title: 'Chapter President', org: 'ICPEP Region 11 (2023 – 2024)' },
    { title: 'Professional Development Officer', org: 'ICPEP Region 11 (2022)' }
];

const workExperience = [
    {
        organization: "TikTok",
        title: "TikTok Live Gaming Streamer",
        date: "OCTOBER 2025 - PRESENT",
        description: "Creates and Manages my Social Media Platforms",
    },
    {
        organization: "X10 Technologies, Inc.",
        title: "Senior Technical Content Writer",
        date: "SEPTEMBER 2023 - JANUARY 2026",
        description: "Global Document Custodian, Records Department Head, Policies and Manuals Writer, RFPs(Canada, US, and Philippines), Technical Reports, Document Controls, Formatting, and Branding"
    },
    {
        organization: "X10 Technologies, Inc.",
        title: "Technical Content Writer",
        date: "JULY 2020 - SEPTEMBER 2023",
        description: "Creating and managing technical documentation and content."

    },
    {
        organization: "TaskBullet Philippines",
        title: "Multi-skilled Virtual Assistant",
        date: "MAY 2020 - OCTOBER 2020",
        description: "Providing diverse virtual assistance services."

    },
    {
        organization: "University of Mindanao Digos College",
        title: "Program Head for Computer Engineering",
        date: "JANUARY 2022 - JANUARY 2023",
        description: "Leadership role in the Computer Engineering program."

    },
    {
        organization: "University of Mindanao Digos College",
        title: "Full-time Engineering Faculty and Lab Custodian",
        date: "JUNE 2019 - JANUARY 2022",
        description: "Academic instruction and laboratory management."
    },
    {
        organization: "The Virtual S Web Solutions | Davao City",
        title: "Administrative Supervisor and Onboarding Trainer",
        date: "OCTOBER 2018 - MAY 2019",
        description: "Administrative Supervisor and Onboarding Trainer"
    },
    {
        organization: "The Virtual S Web Solutions | Davao City",
        title: "All Rounder Administrative Assistant",
        date: "AUGUST 2018 - OCTOBER 2018",
        description: "All Rounder Administrative Assistant"
    },
    {
        organization: "Callbox Philippines Incorporated",
        title: "Technical & Marketing Crew",
        date: "APRIL 2017 - JUNE 2017",
        description: "Technical & Marketing Crew"
    },
    {
        organization: "Launchora",
        title: "Book Author and Self-Help Writer and Speaker",
        date: "AUGUST 2013 - 2022",
        description: "Book Author and Self-Help Writer and Speaker"
    }
];

const achievements = [
{ year: '2022', title: 'Laboratory Safety Series III', org: 'University of Mindanao Digos City', thumbnail: '/images/seminars/lab-thumb.webp', fullRes: '/images/seminars/lab-full.webp'},
{ year: '2022', title: 'Development Management 1: The Leadership That We Want!', org: 'Universidad de Sta. Isabel, Elias Angeles St., Naga City', thumbnail: '/images/seminars/manage-thumb.webp', fullRes: '/images/seminars/manage-full.webp' },
{ year: '2021', title: 'Introduction to Kubernetes', org: 'Trend Micro', thumbnail: '/images/seminars/kube-thumb.webp', fullRes: '/images/seminars/kube-full.webp' },
{ year: '2021', title: '1st International Conference on Emerging Technologies and Innovations (ICETI - 1)', org: 'University of Mindanao', thumbnail: '/images/seminars/confe-thumb.webp', fullRes: '/images/seminars/confe-full.webp' },
{ year: '2021', title: 'Introduction to Amazon Web Services', org: 'Trend Micro', thumbnail: '/images/seminars/aws-thumb.webp', fullRes: '/images/seminars/aws-full.webp'},
{ year: '2021', title: 'Philippine Conference on Data Science and Analytics', org: 'SPARTA', thumbnail: '/images/seminars/sparta-thumb.webp', fullRes: '/images/seminars/sparta-full.webp'},
{ year: '2026', title: 'Future-Ready Careers: Preparing You To Thrive in a World of Innovation and Opportunity', org: 'Holy Cross of Davao College', thumbnail: '/images/seminars/hcdc-thumb.svg', fullRes: '/images/seminars/hcdc-full.svg'},
];

const certificationsList = [
{ title: 'Aruba Data Center Essentials', org: 'Aruba Hewlett Packard Enterprise', thumbnail: '/images/skillCert/arubaThumb.svg', fullRes: '/images/skillCert/arubaFull.svg' },
{ title: 'Certified Computer Engineer', org: 'Computer Engineering Certification Board, Inc.', thumbnail: '/images/skillCert/cpecb.svg', fullRes: '/images/skillCert/cpecbFull.svg' },
    { title: 'DICT-DLS005 Designing Presentation Slides', org: 'Department of Information and Communications Technology', thumbnail: '/images/skillCert/dict3.svg', fullRes: '/images/skillCert/dictFull3.svg' },
    { title: 'DICT-ICT001 Digital Innovation in Government', org: 'Department of Information and Communications Technology', thumbnail: '/images/skillCert/dict1.svg', fullRes: '/images/skillCert/dictFull.svg' },
    { title: 'DICT-DLS002 Navigating Google Workspace', org: 'Department of Information and Communications Technology', thumbnail: '/images/skillCert/dict2.svg', fullRes: '/images/skillCert/dictFull2.svg'},

];
---

<Layout title="CS-Vergara | Portfolio">
    <main class="pt-20 md:pt-24">
        {/* Hero Section */}
        <section class="max-w-7xl mx-auto px-6 md:px-8 py-12 md:py-20 lg:py-32 grid lg:grid-cols-12 gap-12 items-center">
            <div class="lg:col-span-7 text-center lg:text-left">
                <p class="text-primary font-headline tracking-[0.3em] uppercase text-xs md:text-sm mb-6">PROFESSIONAL PORTFOLIO</p>
                <h1 class="text-4xl md:text-5xl lg:text-7xl font-bold font-headline leading-tight md:leading-[1.1] mb-8 tracking-tighter text-on-surface">
                    Engr. Christine Sheen <span class="text-primary">L. Baron-Vergara</span>
                </h1>
                <p class="text-lg md:text-xl text-on-surface-variant font-light max-w-2xl mx-auto lg:mx-0 mb-10 leading-relaxed">
                    Senior Technical Content Writer & Computer Engineer. Bridging the gap between complex engineering concepts and accessible digital narratives.
                </p>
                <div class="flex flex-col sm:flex-row justify-center lg:justify-start gap-4">
                    <a
                        href="/contact"
                        class="bg-gradient-to-r from-primary to-primary-container text-on-primary px-10 py-4 rounded-lg font-bold text-sm tracking-widest uppercase hover:opacity-90 transition-all text-center"
                    >
                        Contact Me
                    </a>
                    <button
                        onclick="window.open('https://drive.google.com/file/d/1Vwc1vTizW_bmAb3fBd2BCIDlyw8ZedZF/view?usp=sharing', '_blank')"
                        class="border border-outline-variant/20 text-on-surface px-10 py-4 rounded-lg font-bold text-sm tracking-widest uppercase hover:bg-surface-container-low transition-all text-center">
                        View Resume
                    </button>
                </div>
            </div>
            <div class="lg:col-span-5 relative order-first lg:order-last">
                <div class="aspect-square md:aspect-[4/5] max-w-md mx-auto bg-surface-container-low rounded-lg overflow-hidden transition-all duration-700">
                    <img
                        class="w-full h-full object-cover"
                        alt="Professional portrait of Engr. Christine Sheen"
                        src="/images/profile.png"  
                    />
                </div>
                <div class="absolute -bottom-6 -right-6 md:-left-6 bg-primary text-on-primary p-4 md:p-6 rounded-lg">
                    <p class="text-2xl md:text-3xl font-bold font-headline">10+</p>
                    <p class="text-[10px] md:text-xs uppercase tracking-tighter opacity-80">Years of Experience</p>
                </div>
            </div>
        </section>

        {/* About & Bento Grid */}
        <section class="bg-surface-container-low py-16 md:py-24">
            <div class="max-w-7xl mx-auto px-6 md:px-8">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                    {/* About Me */}
                    <div class="md:col-span-2 bg-surface p-6 md:p-10 rounded-lg">
                        <h2 class="text-2xl md:text-3xl font-bold font-headline mb-6 md:mb-8 text-primary">About Me</h2>
                        <p class="text-on-surface-variant leading-relaxed text-base md:text-lg">
                            With a dual background in Computer Engineering and Technical Writing, I specialize in distilling intricate technological frameworks into compelling, high-authority content. My approach combines technical precision with editorial flair, ensuring that every project is both accurate and engaging.
                        </p>
                        <div class="mt-8 md:mt-12 grid grid-cols-1 sm:grid-cols-2 gap-8 border-t border-outline-variant/10 pt-8 md:pt-10">
                            <div>
                                <h4 class="text-primary font-headline text-xs md:text-sm uppercase tracking-widest mb-2">Location</h4>
                                <p class="text-on-surface text-sm md:text-base">Davao City, Philippines</p>
                            </div>
                            <div>
                                <h4 class="text-primary font-headline text-xs md:text-sm uppercase tracking-widest mb-2">Specialization</h4>
                                <p class="text-on-surface text-sm md:text-base">ISO/IEC 27001, Document Manager, ISO Auditor, Startup Mentor, Business Analyst</p>
                            </div>
                        </div>
                    </div>
                    {/* Strengths */}
                    <div class="bg-surface-container-highest p-6 md:p-10 rounded-lg flex flex-col justify-between">
                        <div>
                            <h2 class="text-2xl md:text-3xl font-bold font-headline mb-6 md:mb-8 text-white">Strengths</h2>
                            <ul class="space-y-4 md:space-y-6">
                                <li class="flex items-center gap-4">
                                    <span class="material-symbols-outlined text-primary">chat</span>
                                    <span class="text-on-surface font-medium text-sm md:text-base">Precise Verbal Communication</span>
                                </li>
                                <li class="flex items-center gap-4">
                                    <span class="material-symbols-outlined text-primary">edit_note</span>
                                    <span class="text-on-surface font-medium text-sm md:text-base">Proficient Technical Writing</span>
                                </li>
                                <li class="flex items-center gap-4">
                                    <span class="material-symbols-outlined text-primary">groups</span>
                                    <span class="text-on-surface font-medium text-sm md:text-base">Excellent Team Coordination</span>
                                </li>
                                <li class="flex items-center gap-4">
                                    <span class="material-symbols-outlined text-primary">bolt</span>
                                    <span class="text-on-surface font-medium text-sm md:text-base">High Efficiency & Productivity</span>
                                </li>
                                <li class="flex items-center gap-4">
                                    <span class="material-symbols-outlined text-primary">build</span>
                                    <span class="text-on-surface font-medium text-sm md:text-base">Technical Troubleshooting</span>
                                </li>
                                <li class="flex items-center gap-4">
                                    <span class="material-symbols-outlined text-primary">leaderboard</span>
                                    <span class="text-on-surface font-medium text-sm md:text-base">Adaptable Leadership</span>
                                </li>
                            </ul>
                        </div>
                        <div class="mt-8 hidden md:block">
                            <span class="text-4xl material-symbols-outlined text-white/20">format_quote</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        {/* Work Experience Timeline */}
        <WorkExperienceTimeline experiences={workExperience} />

        {/* Technical Skills & Affiliations */}
        <section class="bg-surface-container py-16 md:py-24">
            <div class="max-w-7xl mx-auto px-6 md:px-8 grid lg:grid-cols-2 gap-12 md:gap-20">
                <div>
                    <h2 class="text-2xl md:text-3xl font-bold font-headline mb-8 md:mb-10 text-primary">Technical Skills</h2>
                    <div class="flex flex-wrap gap-2 md:gap-3">
                        {technicalSkills.map((skill) => (
                            <span class="px-4 md:px-6 py-1.5 md:py-2 bg-surface-container-highest text-secondary font-medium rounded-full text-xs md:text-sm border border-outline-variant/10">
                                {skill}
                            </span>
                        ))}
                    </div>
                    <h2 class="text-2xl md:text-3xl font-bold font-headline mb-8 md:mb-10 mt-12 md:mt-20 text-white">Affiliations</h2>
                    <div class="space-y-4 md:space-y-6">
                        {affiliations.map((aff) => (
                            <div class="flex items-start gap-4 p-4 bg-surface-container-low rounded-lg border-l-4 border-primary">
                                <span class="material-symbols-outlined text-primary pt-1 text-xl md:text-2xl">verified</span>
                                <div>
                                    <p class="font-bold text-on-surface text-sm md:text-base">{aff.title}</p>
                                    <p class="text-[10px] md:text-xs text-on-surface-variant uppercase tracking-widest">{aff.org}</p>
                                </div>
                            </div>
                        ))}
                    </div>
                </div>
                <div class="grid grid-cols-1 gap-8">
                    {/* Education */}
                    <div class="bg-surface p-6 md:p-8 rounded-lg border border-outline-variant/10">
                        <h2 class="text-xl md:text-2xl font-bold font-headline mb-4 md:mb-6 text-primary flex items-center gap-3">
                            <span class="material-symbols-outlined">school</span> Education
                        </h2>
                        <div class="space-y-4 md:space-y-6">
                            <div>
                                <p class="font-bold text-on-surface text-sm md:text-base">BS in Computer Engineering</p>
                                <p class="text-xs md:text-sm text-on-surface-variant">University of Mindanao</p>
                                <p class="text-[10px] md:text-xs text-primary mt-1">Graduated April 2019</p>
                            </div>
                            <div class="border-t border-outline-variant/10 pt-4">
                                <p class="font-bold text-on-surface text-sm md:text-base">Master of Business Administration</p>
                                <p class="text-xs md:text-sm text-on-surface-variant">Ongoing Research</p>
                            </div>
                        </div>
                    </div>
                    {/* Certifications */}
                    <div class="bg-surface p-6 md:p-8 rounded-2xl border border-outline-variant/10 shadow-xl shadow-black/20">
                        <h2 class="text-xl md:text-2xl font-bold font-headline mb-6 md:mb-8 text-primary flex items-center gap-3">
                            <span class="material-symbols-outlined bg-primary/10 p-2 rounded-lg">card_membership</span> Certifications
                        </h2>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 md:gap-4">
                            {certificationsList.map((cert) => (
                                <CertModal 
                                    variant="list"
                                    title={cert.title}
                                    organization={cert.org}
                                    thumbnailSrc={cert.thumbnail}
                                    fullResSrc={cert.fullRes}
                                    alt={cert.title}
                                />
                            ))}
                        </div>
                    </div>
                </div>
            </div>
        </section>

        {/* Seminars & Achievements */}
        <section class="max-w-7xl mx-auto px-6 md:px-8 py-16 md:py-24">
            <div class="flex flex-col md:flex-row md:items-end justify-between mb-10 md:mb-16 gap-4">
                <div>
                    <h2 class="text-3xl md:text-5xl font-bold font-headline mb-4">Seminars & <span class="text-primary">Achievements</span></h2>
                    <p class="text-on-surface-variant max-w-2xl">A collection of professional development milestones, technical workshops, and industry conferences I've participated in over the years.</p>
                </div>
            </div>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
                {achievements.map((ach) => (
                <CertModal
                  thumbnailSrc={ach.thumbnail}
                  fullResSrc={ach.fullRes}
                  alt={ach.title}
                  title={ach.title}
                  year={ach.year}
                  organization={ach.org}
                />
                ))}
            </div>
        </section>
    </main>
</Layout>
