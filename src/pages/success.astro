---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Message Sent | Engr. CS">
    {/* TopNavBar */}
    <nav class="fixed top-0 w-full z-50 bg-background/60 backdrop-blur-xl">
        <div class="flex justify-between items-center px-8 py-6 w-full max-w-7xl mx-auto">
            <a class="text-2xl font-black tracking-tighter text-primary font-headline uppercase" href="/">engr. cs</a>
            <div class="hidden md:flex items-center gap-10">
                <a class="font-headline uppercase tracking-tight text-sm text-white/70 hover:text-white transition-colors" href="/">HOME</a>
                <a class="font-headline uppercase tracking-tight text-sm text-white/70 hover:text-white transition-colors" href="/blog">BLOG</a>
                <a class="font-headline uppercase tracking-tight text-sm text-white/70 hover:text-white transition-colors" href="/contact">CONTACT</a>
            </div>
        </div>
    </nav>

    <main class="min-h-[80vh] flex flex-col items-center justify-center px-8 text-center">
        <div class="max-w-2xl w-full bg-surface-container rounded-lg p-12 md:p-20 relative overflow-hidden">
            {/* Abstract Background Decoration */}
            <div class="absolute -top-24 -right-24 w-64 h-64 bg-primary/5 rounded-full blur-3xl"></div>
            
            <div class="relative z-10">
                <span class="material-symbols-outlined text-primary text-6xl mb-6">check_circle</span>
                <h1 class="font-headline text-5xl md:text-7xl font-bold tracking-tighter leading-tight text-white mb-6">
                    MESSAGE <span class="text-primary italic">SENT!</span>
                </h1>
                <p class="text-on-surface-variant text-lg md:text-xl font-light mb-12 leading-relaxed">
                    Thank you for reaching out. I've received your inquiry and will get back to you within 24-48 business hours.
                </p>

                <div class="flex flex-col sm:flex-row items-center justify-center gap-6 mb-16">
                    <a href="/" class="bg-primary text-on-primary group relative inline-flex items-center gap-3 px-8 py-4 rounded-md font-headline font-bold uppercase tracking-tighter hover:scale-[1.05] transition-transform">
                        <span>Return Home</span>
                        <span class="material-symbols-outlined text-lg">home</span>
                    </a>
                </div>

                <div class="pt-12 border-t border-white/10">
                    <p class="font-label text-xs uppercase tracking-widest text-primary/60 mb-6">While you wait, let's connect:</p>
                    <div class="flex justify-center gap-8">
                        <a href="https://www.linkedin.com/in/engrchristinevergara/" target="_blank" class="flex items-center gap-2 text-white/80 hover:text-primary transition-colors group">
                            <span class="font-headline font-bold">LinkedIn</span>
                            <span class="material-symbols-outlined text-sm group-hover:translate-x-1 transition-transform">north_east</span>
                        </a>
                        <a href="https://www.tiktok.com/@engr.tinayccpe" target="_blank" class="flex items-center gap-2 text-white/80 hover:text-primary transition-colors group">
                            <span class="font-headline font-bold">TikTok</span>
                            <span class="material-symbols-outlined text-sm group-hover:translate-x-1 transition-transform">north_east</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </main>
</Layout>
