---
// Props passed from index.astro
const { experiences } = Astro.props;
---
<section class="max-w-7xl mx-auto px-6 md:px-8 py-16 md:py-24">
    <h2 class="text-3xl md:text-4xl font-bold font-headline mb-12 md:mb-16 text-center">Work <span class="text-primary">Experience</span></h2>
    <div class="space-y-12 relative before:absolute before:left-2 md:before:left-1/2 before:w-[1px] before:h-full before:bg-outline-variant/30">
        {experiences.map((exp, index) => (
            <div class="relative flex flex-col md:flex-row items-center gap-6 md:gap-8 group">
                {index % 2 === 0 ? (
                    <>
                        <div class="md:w-1/2 md:text-right pl-10 md:pl-0 md:pr-12 order-2 md:order-1 w-full">
                            <span class="text-primary font-bold font-headline text-xs md:text-sm tracking-widest mb-2 block uppercase">{exp.date}</span>
                            <h3 class="text-xl md:text-2xl font-bold text-white mb-2">{exp.title}</h3>
                            <p class="text-on-surface-variant italic mb-3 text-sm md:text-base">{exp.organization}</p>
                            <p class="text-on-surface-variant text-sm md:text-base max-w-md md:ml-auto">{exp.description}</p>
                        </div>
                        <div class="hidden md:block md:w-1/2 order-3"></div>
                    </>
                ) : (
                    <>
                        <div class="hidden md:block md:w-1/2 order-1"></div>
                        <div class="md:w-1/2 pl-10 md:pl-12 order-2 md:order-3 w-full">
                            <span class="text-primary font-bold font-headline text-xs md:text-sm tracking-widest mb-2 block uppercase">{exp.date}</span>
                            <h3 class="text-xl md:text-2xl font-bold text-white mb-2">{exp.title}</h3>
                            <p class="text-on-surface-variant italic mb-3 text-sm md:text-base">{exp.organization}</p>
                            <p class="text-on-surface-variant text-sm md:text-base max-w-md">{exp.description}</p>
                        </div>
                    </>
                )}
                <div class={`absolute left-0 md:left-1/2 md:translate-x-[-50%] w-4 h-4 md:w-5 md:h-5 ${index % 2 === 0 ? 'bg-primary' : 'bg-primary-container'} rounded-full z-10 border-4 border-surface shadow-[0_0_15px_rgba(255,20,147,0.4)] top-1 md:top-auto`}></div>
            </div>
        ))}
    </div>
</section>