---
---
<header class="glass">
	<nav class="container">
		<a href="/" class="logo">ASTRO<span>BLOG</span></a>
		<div class="links">
			<a href="/">Home</a>
			<a href="/blog">Blog</a>
			<a href="/subscribe" class="cta">Subscribe</a>
		</div>
	</nav>
</header>

<style>
	header {
		position: sticky;
		top: 1rem;
		margin: 0 1rem;
		z-index: 100;
		border-radius: 50px !important;
		padding: 0.75rem 0;
	}

	nav {
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.logo {
		font-size: 1.5rem;
		font-weight: 900;
		letter-spacing: -0.05em;
	}

	.logo span {
		color: var(--accent);
	}

	.links {
		display: flex;
		gap: 2rem;
		align-items: center;
	}

	.links a {
		font-weight: 500;
		font-size: 0.9rem;
	}

	.cta {
		background: var(--accent);
		color: white !important;
		padding: 0.5rem 1.25rem;
		border-radius: 50px;
		transition: transform 0.2s ease, background 0.2s ease;
	}

	.cta:hover {
		background: var(--accent-light);
		transform: translateY(-1px);
	}

	@media (max-width: 600px) {
		.links {
			gap: 1rem;
		}
		.cta {
			display: none;
		}
	}
</style>
