---
const { pathname } = Astro.url;
const normalizedPathname = pathname.replace(/\/$/, "");

const navLinks = [
  { href: "/", label: "Home" },
  { href: "/blog", label: "Blog" },
  { href: "/contact", label: "Contact" },
];
---

<nav class="fixed top-0 w-full z-50 bg-background/60 backdrop-blur-xl">
    <div class="flex justify-between items-center px-8 py-6 max-w-7xl mx-auto w-full">
      <a href="/" class="block">
        <img 
            src="/images/screen2.png"
            alt="VBTecH Solutions Logo"
            class="h-20 w-auto object-contain transition-transform duration-300 ease-in-out hover:scale-110"
        />
      </a>
        <div class="hidden md:flex gap-8 items-center">
            {navLinks.map(({ href, label }) => {
                const isActive = normalizedPathname === (href === "/" ? "" : href);
                return (
                    <a
                        class={`font-headline uppercase tracking-widest text-sm transition-colors duration-300 scale-95 active:duration-100 ${
                            isActive 
                            ? "text-primary border-b-2 border-primary pb-1" 
                            : "text-white/70 hover:text-primary"
                        }`}
                        href={href}
                    >
                        {label}
                    </a>
                );
            })}
        </div>
    </div>
</nav>
