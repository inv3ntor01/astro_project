---
const { pathname } = Astro.url;
const normalizedPathname = pathname.replace(/\/$/, "");

const navLinks = [
  { href: "/", label: "Home" },
  { href: "/blog", label: "Blog" },
  { href: "/contact", label: "Contact" },
];
---

<nav class="fixed top-0 w-full z-50 bg-background/60 backdrop-blur-xl border-b border-white/5">
    <div class="flex justify-between items-center px-6 md:px-8 py-4 md:py-6 max-w-7xl mx-auto w-full">
      <a href="/" class="block z-50">
        <img 
            src="/images/screen2.png"
            alt="VBTecH Solutions Logo"
            class="h-12 md:h-20 w-auto object-contain transition-transform duration-300 ease-in-out hover:scale-110"
        />
      </a>

        <!-- Desktop Menu -->
        <div class="hidden md:flex gap-8 items-center">
            {navLinks.map(({ href, label }) => {
                const isActive = normalizedPathname === (href === "/" ? "" : href);
                return (
                    <a
                        class={`font-headline uppercase tracking-widest text-sm transition-colors duration-300 scale-95 active:duration-100 ${
                            isActive 
                            ? "text-primary border-b-2 border-primary pb-1" 
                            : "text-white/70 hover:text-primary"
                        }`}
                        href={href}
                    >
                        {label}
                    </a>
                );
            })}
        </div>

        <!-- Mobile Menu Toggle -->
        <button 
            id="menu-toggle" 
            class="md:hidden z-50 p-2 text-white/70 hover:text-primary transition-colors focus:outline-none"
            aria-label="Toggle Menu"
        >
            <span class="material-symbols-outlined text-3xl" id="menu-icon">menu</span>
        </button>
    </div>

    <!-- Mobile Menu Overlay -->
    <div 
        id="mobile-menu" 
        class="fixed inset-0 bg-background/95 backdrop-blur-2xl z-40 flex flex-col items-center justify-center gap-8 transition-all duration-300 opacity-0 pointer-events-none"
    >
        {navLinks.map(({ href, label }) => {
            const isActive = normalizedPathname === (href === "/" ? "" : href);
            return (
                <a
                    class={`font-headline uppercase tracking-[0.2em] text-2xl transition-all duration-300 ${
                        isActive 
                        ? "text-primary scale-110" 
                        : "text-white/70 hover:text-primary"
                    }`}
                    href={href}
                >
                    {label}
                </a>
            );
        })}
    </div>
</nav>

<script>
    const menuToggle = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuIcon = document.getElementById('menu-icon');
    let isMenuOpen = false;

    if (menuToggle && mobileMenu && menuIcon) {
        menuToggle.addEventListener('click', () => {
            isMenuOpen = !isMenuOpen;
            
            if (isMenuOpen) {
                mobileMenu.classList.remove('opacity-0', 'pointer-events-none');
                mobileMenu.classList.add('opacity-100');
                menuIcon.textContent = 'close';
                document.body.style.overflow = 'hidden';
            } else {
                mobileMenu.classList.add('opacity-0', 'pointer-events-none');
                mobileMenu.classList.remove('opacity-100');
                menuIcon.textContent = 'menu';
                document.body.style.overflow = '';
            }
        });

        // Close menu when clicking a link
        const mobileLinks = mobileMenu.querySelectorAll('a');
        mobileLinks.forEach(link => {
            link.addEventListener('click', () => {
                isMenuOpen = false;
                mobileMenu.classList.add('opacity-0', 'pointer-events-none');
                mobileMenu.classList.remove('opacity-100');
                menuIcon.textContent = 'menu';
                document.body.style.overflow = '';
            });
        });
    }
</script>
