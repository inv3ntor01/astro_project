---
interface Props {
  thumbnailSrc: string;
  fullResSrc: string;
  alt: string;
  title?: string;
  organization?: string;
  year?: string;
  className?: string;
}

const { thumbnailSrc, fullResSrc, alt, organization, title, year, className= '' } = Astro.props;
---

<div class={`cert-wrapper ${className}`}>
  <!-- 1. The Card (Trigger) -->
  <button class="cert-trigger group/cert relative bg-surface-container-low rounded-xl overflow-hidden border border-outline-variant/10 hover:border-primary/50 transition-all duration-500 hover:shadow-2xl hover:shadow-primary/20" aria-label="View certification">
    <!-- Image Section -->
    <div class="relative overflow-hidden aspect-[4/3]">
      <img src={thumbnailSrc} alt={alt} loading="lazy" class="w-full h-full object-fit transition-transform duration-700 group-hover/cert:scale-110" />
      <div class="absolute inset-0 bg-gradient-to-t from-surface-container-low via-transparent to-transparent opacity-60"></div>
      
      <!-- Hover Overlay Badge -->
      <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover/cert:opacity-100 transition-opacity duration-300 bg-primary/10 backdrop-blur-[2px]">
        <div class="bg-primary text-on-primary px-4 py-2 rounded-full flex items-center gap-2 transform translate-y-4 group-hover/cert:translate-y-0 transition-transform duration-300 shadow-lg">
          <span class="material-symbols-outlined text-lg">visibility</span>
          <span class="text-xs font-bold uppercase tracking-wider">View Certificate</span>
        </div>
      </div>
    </div>

    <!-- Content Section -->
    <div class="p-5 text-left relative z-10">
      <div class="flex items-center gap-2 mb-2">
        {year && <span class="px-2 py-0.5 bg-primary/10 text-primary text-[10px] font-bold rounded-md border border-primary/20 uppercase tracking-tighter">{year}</span>}
        <span class="h-px flex-1 bg-outline-variant/20"></span>
      </div>
      {title && <h4 class="text-on-surface font-bold text-sm md:text-base leading-snug mb-1 group-hover/cert:text-primary transition-colors duration-300">{title}</h4>}
      {organization && <p class="text-on-surface-variant text-xs md:text-sm line-clamp-1">{organization}</p>}
    </div>
  </button>

  <!-- 2. The Modal (Hidden by default) -->
  <div class="cert-modal fixed inset-0 z-[100] flex items-center justify-center p-4 md:p-8 opacity-0 invisible transition-all duration-300 pointer-events-none" role="dialog" aria-modal="true" aria-hidden="true">
    <div class="modal-backdrop absolute inset-0 bg-surface-container-lowest/95 backdrop-blur-md cursor-pointer"></div>

    <div class="modal-content relative z-[101] w-full max-w-5xl bg-surface border border-outline-variant/20 rounded-2xl overflow-hidden shadow-2xl transform scale-95 transition-transform duration-300">
      <button class="close-btn absolute top-4 right-4 z-[102] w-10 h-10 flex items-center justify-center bg-surface-container-high hover:bg-primary hover:text-on-primary rounded-full text-on-surface transition-all duration-200" aria-label="Close modal">
        <span class="material-symbols-outlined">close</span>
      </button>

      <div class="flex flex-col md:flex-row">
        <div class="relative w-full md:w-2/3 aspect-auto bg-black flex items-center justify-center overflow-hidden">
          <img src={fullResSrc} alt={alt} class="max-w-full max-h-[80vh] object-contain pointer-events-none" />
          <div class="image-shield absolute inset-0 z-10"></div>
        </div>
        
        <div class="w-full md:w-1/3 p-6 md:p-8 flex flex-col justify-center bg-surface-container-low">
            <div class="mb-6">
                <span class="text-primary font-bold text-xs uppercase tracking-widest mb-2 block">Achievement</span>
                <h3 class="text-2xl font-bold font-headline text-on-surface mb-4 leading-tight">{title}</h3>
                <div class="flex items-center gap-3 text-on-surface-variant mb-6">
                    <span class="material-symbols-outlined text-primary">corporate_fare</span>
                    <span class="text-sm font-medium">{organization}</span>
                </div>
                {year && (
                    <div class="flex items-center gap-3 text-on-surface-variant">
                        <span class="material-symbols-outlined text-primary">calendar_today</span>
                        <span class="text-sm font-medium">{year}</span>
                    </div>
                )}
            </div>
            
            <div class="mt-auto">
                <p class="text-xs text-on-surface-variant italic leading-relaxed opacity-60">
                    Verification of participation and successful completion of the stated program or achievement.
                </p>
            </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  /* Active State (Added via JS) */
  .cert-modal.is-open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .cert-modal.is-open .modal-content {
    transform: scale(1);
  }
</style>

<script>
  function setupCertModals() {
    const wrappers = document.querySelectorAll('.cert-wrapper');

    wrappers.forEach((wrapper) => {
      const trigger = wrapper.querySelector('.cert-trigger');
      const modal = wrapper.querySelector('.cert-modal');
      const backdrop = wrapper.querySelector('.modal-backdrop');
      const closeBtn = wrapper.querySelector('.close-btn');

      if (!trigger || !modal) return;

      const openModal = () => {
        modal.classList.add('is-open');
        modal.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      };

      const closeModal = () => {
        modal.classList.remove('is-open');
        modal.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      };

      trigger.addEventListener('click', openModal);
      backdrop?.addEventListener('click', closeModal);
      closeBtn?.addEventListener('click', closeModal);

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && modal.classList.contains('is-open')) {
          closeModal();
        }
      });

      const shield = wrapper.querySelector('.image-shield');
      if(shield) {
        shield.addEventListener('contextmenu', (e) => e.preventDefault());
      }
    });
  }

  // Setup on initial load
  setupCertModals();

  // Setup on view transitions if applicable
  document.addEventListener('astro:page-load', setupCertModals);
</script>
