---
/*import SubscriptionForm from './SubscriptionForm.astro';*/
const currentYear = new Date().getFullYear();

const socialLinks = [
  {
    label: 'Email',
    href: "mailto:engineerbaron28@gmail.com",
    external: false,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path d="M1.5 8.67v8.58a3 3 0 003 3h15a3 3 0 003-3V8.67l-8.928 5.493a3 3 0 01-3.144 0L1.5 8.67z" /><path d="M22.5 6.908V6.75a3 3 0 00-3-3h-15a3 3 0 00-3 3v.158l9.714 5.978a1.5 1.5 0 001.572 0L22.5 6.908z" /></svg>`
  },
  {
    label: 'TikTok',
    href: 'https://www.tiktok.com/@engr.tinayccpe?is_from_webapp=1&sender_device=pc',
    external: true,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-5.2 1.74 2.89 2.89 0 012.31-4.64 2.93 2.93 0 01.88.13V9.4a6.84 6.84 0 00-1-.05A6.33 6.33 0 005 20.1a6.34 6.34 0 0010.86-4.43v-7a8.16 8.16 0 004.77 1.52v-3.4a4.85 4.85 0 01-1-.1z" /></svg>`
  },
  {
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/in/engrchristinevergara/',
    external: true,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" /></svg>`
  },
];
---

<footer class="bg-surface-container-lowest w-full py-12 px-8 mt-20 border-t border-white/10">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-8">

    <!-- Brand & Copyright -->
    <div class="text-center md:text-left">
      <span class="font-headline text-lg text-white block mb-2 uppercase tracking-widest">
        engr. cs
      </span>
      <p class="font-body text-xs tracking-tight text-white/40">
        © {currentYear} Virtual Buddy Solutions
      </p>
    </div>

    <!-- Social Icons -->
    <nav class="flex gap-8" aria-label="Social Media Links">
      {socialLinks.map((link) => (
        <a
          href={link.href}
          aria-label={link.label}
          class="text-white transition-all duration-300 hover:scale-110 focus:outline-none focus:ring-2 focus:ring-white/50 rounded-full p-1"
          {...(link.external && {
            target: '_blank',
            rel: 'noopener noreferrer',
          })}
        >
          <span set:html={link.icon} />
        </a>
      ))}
    </nav>

    <!-- Designer Credit -->
    <div class="text-center md:text-right">
      <p class="font-body text-xs tracking-tight text-white/20 uppercase">
        Designed by Inv3ntor
      </p>
    </div>

  </div>
</footer>
