---
interface Props {
	post: any;
}

const { post } = Astro.props;
---
<article class="glass post-card">
	{post.data.heroImage && (
		<div class="image-wrapper">
			<img src={post.data.heroImage} alt={post.data.title} loading="lazy" />
		</div>
	)}
	<div class="content">
		<time datetime={post.data.pubDate.toISOString()}>
			{post.data.pubDate.toLocaleDateString('en-US', {
				year: 'numeric',
				month: 'long',
				day: 'numeric',
			})}
		</time>
		<h3><a href={`/blog/${post.id}/`}>{post.data.title}</a></h3>
		<p>{post.data.description}</p>
		<a href={`/blog/${post.id}/`} class="read-more">Read Article &rarr;</a>
	</div>
</article>

<style>
	.post-card {
		overflow: hidden;
		display: flex;
		flex-direction: column;
		height: 100%;
		transition: transform 0.3s ease, border-color 0.3s ease;
	}

	.post-card:hover {
		transform: translateY(-5px);
		border-color: var(--accent);
	}

	.image-wrapper {
		height: 200px;
		width: 100%;
		overflow: hidden;
	}

	img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.5s ease;
	}

	.post-card:hover img {
		transform: scale(1.05);
	}

	.content {
		padding: 1.5rem;
		display: flex;
		flex-direction: column;
		flex: 1;
	}

	time {
		font-size: 0.8rem;
		color: var(--accent-light);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: 0.5rem;
	}

	h3 {
		font-size: 1.25rem;
		margin-bottom: 1rem;
		line-height: 1.3;
	}

	p {
		font-size: 0.95rem;
		color: var(--muted);
		margin-bottom: 1.5rem;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
		flex: 1;
	}

	.read-more {
		font-size: 0.9rem;
		font-weight: 700;
		color: var(--fg);
	}
</style>
